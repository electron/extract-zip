# ── Build output ──────────────────────────────────────────────────────────
/target/
*.node
*.wasm
# Generated by `napi build --js binding.js --dts binding.d.ts` (then post-
# processed by scripts/strip-binding-fallbacks.js). `index.js` is hand-written.
/binding.js
/binding.d.ts

# ── Dependencies ──────────────────────────────────────────────────────────
/node_modules/
.yarn/*
!.yarn/releases
!.yarn/plugins
!.yarn/patches
.pnp.*

# ── Test & benchmark artefacts ────────────────────────────────────────────
/test/fixtures/
/test/out/
/bench/.cache/
/bench/out/

# ── Security-audit agent working files ────────────────────────────────────
# A background agent drops PoC scripts and reports while reviewing; none of
# it should land in git.
audit-*.js
audit-*.ts
audit-*.md
*-poc.js
*-poc.ts
*.poc
/.audit/
/security-report*

# ── OS / editor ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# ── Logs & temp ───────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-error.log*
*.tmp
*.bak
.env
.env.*

# ── Packaging ─────────────────────────────────────────────────────────────
*.tgz
/artifacts/
/npm/
